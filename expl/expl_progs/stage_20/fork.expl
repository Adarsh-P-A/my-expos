int main ()
{
    decl
        int temp;
        int pid;
        str name;
    enddecl

    begin
        pid = exposcall("Fork");
        if(pid == 0) then
            temp = exposcall("Write", -2, "Child");
            temp = exposcall("Exec", "odd.xsm");
        else
            temp = exposcall("Write", -2, "Parent");
            temp = exposcall("Exec", "even.xsm");
        endif;

        return 0;
    end
}