load --exec $HOME/myexpos/expl/samples/prime.xsm
load --exec $HOME/myexpos/expl/samples/bb_sort.xsm
load --library $HOME/myexpos/expl/library.lib
load --idle $HOME/myexpos/expl/samples/idle.xsm
load --int=6 $HOME/myexpos/spl/spl_progs/stage_18/int6.xsm
load --int=7 $HOME/myexpos/spl/spl_progs/stage_18/int7.xsm
load --int=9 $HOME/myexpos/spl/spl_progs/stage_18/int9.xsm
load --int=10 $HOME/myexpos/spl/spl_progs/stage_18/int10.xsm
load --int=timer $HOME/myexpos/spl/spl_progs/stage_18/timer.xsm
load --int=console $HOME/myexpos/spl/spl_progs/stage_18/console_interrupt_handler.xsm
load --int=disk $HOME/myexpos/spl/spl_progs/stage_18/disk_interrupt_handler.xsm
load --module 0 $HOME/myexpos/spl/spl_progs/stage_18/mod0.xsm
load --module 1 $HOME/myexpos/spl/spl_progs/stage_18/mod1.xsm
load --module 2 $HOME/myexpos/spl/spl_progs/stage_18/mod2.xsm
load --module 4 $HOME/myexpos/spl/spl_progs/stage_18/mod4.xsm
load --module 5 $HOME/myexpos/spl/spl_progs/stage_18/scheduler.xsm
load --module 7 $HOME/myexpos/spl/spl_progs/stage_18/boot_module.xsm
load --exhandler $HOME/myexpos/spl/spl_progs/stage_18/exception.xsm