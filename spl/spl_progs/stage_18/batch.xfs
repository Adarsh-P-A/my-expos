fdisk
load --os $HOME/myexpos/spl/spl_progs/stage_18/os_startup_module.xsm
load --init $HOME/myexpos/expl/expl_progs/stage_17/shell.xsm
load --exec $HOME/myexpos/expl/samples/numbers.xsm
